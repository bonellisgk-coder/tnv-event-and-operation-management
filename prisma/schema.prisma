datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x", "linux-musl", "linux-musl-openssl-3.0.x"]
}

enum Role {
  SUPER_ADMIN
  DEPARTMENT_ADMIN
  VOLUNTEER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  ONGOING
  COMPLETED
  CANCELLED
}

enum ParticipantStatus {
  PENDING
  CONFIRMED
  PRESENT
  ABSENT
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id               String            @id @default(uuid())
  name             String
  email            String            @unique
  phone            String
  passwordHash     String
  role             Role              @default(VOLUNTEER)
  departmentId     String?
  department       Department?       @relation(fields: [departmentId], references: [id])
  assignedTasks    Task[]            @relation("TaskAssignee")
  createdTasks     Task[]            @relation("TaskCreator")
  resetTokens      PasswordResetToken[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Department {
  id               String   @id @default(uuid())
  name             String   @unique
  users            User[]
  events           Event[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Event {
  id                   String                @id @default(uuid())
  slug                 String                @unique
  title                String
  description          String
  date                 DateTime
  startTime            String
  endTime              String
  venue                String
  type                 String
  status               EventStatus           @default(DRAFT)
  checkinEnabled       Boolean               @default(false)
  departmentId         String?
  department           Department?           @relation(fields: [departmentId], references: [id])
  participants         Participant[]
  certificateTemplates CertificateTemplate[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model Participant {
  id               String             @id @default(uuid())
  eventId          String
  event            Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name             String
  email            String
  phone            String
  status           ParticipantStatus  @default(PENDING)
  editToken        String             @unique
  editTokenExpires DateTime
  checkinAt        DateTime?
  additionalMembers AdditionalMember[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model AdditionalMember {
  id            String      @id @default(uuid())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  name          String
  email         String?
  createdAt     DateTime    @default(now())
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String
  assigneeId  String
  assignee    User         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creatorId   String?
  creator     User?        @relation("TaskCreator", fields: [creatorId], references: [id])
  priority    TaskPriority @default(MEDIUM)
  deadline    DateTime
  status      TaskStatus   @default(TODO)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model CertificateTemplate {
  id            String   @id @default(uuid())
  eventId       String   @unique
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  imageUrl      String
  namePosition  Json
  qrPosition    Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
